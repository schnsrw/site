---
/**
 * Top navigation. Sticky, blurred backdrop.
 *
 * `active` prop highlights the matching link. Pages pass the route slug
 * ('home' | 'sheets' | 'editor' | 'desktop' | 'docs' | 'changelog' | 'about').
 *
 * The right-most "★ Star on GitHub" affordance is the primary CTA on
 * a community-first project — louder than the dim text links beside
 * it, but still a pill not a button so it doesn't feel salesy.
 */
type ActiveLink = 'home' | 'sheets' | 'editor' | 'desktop' | 'docs' | 'changelog' | 'about';
const { active = 'home' } = Astro.props as { active?: ActiveLink };

const link = (slug: ActiveLink) =>
  slug === active ? 'nav__link nav__link--active' : 'nav__link';
---

<nav class="nav" aria-label="Primary">
  <a class="nav__brand" href="/" aria-label="Casual Office home">
    <span class="nav__mark" aria-hidden="true"></span>
    Casual Office
  </a>
  <div class="nav__links">
    <a class={link('sheets')} href="/casual-sheets/" aria-current={active === 'sheets' ? 'page' : undefined}>Sheets</a>
    <a class={link('editor')} href="/casual-editor/" aria-current={active === 'editor' ? 'page' : undefined}>Editor</a>
    <a class={link('desktop')} href="/casual-desktop/" aria-current={active === 'desktop' ? 'page' : undefined}>Desktop</a>
    <a class={link('docs')} href="/docs/" aria-current={active === 'docs' ? 'page' : undefined}>Docs</a>
    <a class={link('changelog')} href="/changelog/" aria-current={active === 'changelog' ? 'page' : undefined}>Changelog</a>
    <a
      class="nav__star"
      href="https://github.com/schnsrw"
      rel="noopener"
      target="_blank"
      aria-label="View on GitHub"
    >
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
        <path
          fill="currentColor"
          d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
        />
      </svg>
      <span class="nav__star-label">Star on GitHub</span>
    </a>
  </div>
</nav>

<style>
  .nav__star {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    margin-left: 8px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    transition:
      border-color 120ms ease,
      background-color 120ms ease,
      color 120ms ease;
    background: var(--surface);
  }
  .nav__star:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-strong);
  }
  @media (max-width: 720px) {
    .nav__star-label {
      display: none;
    }
    .nav__star {
      padding: 6px 10px;
      gap: 0;
    }
  }
</style>
