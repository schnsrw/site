---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';

const title = 'Casual Office — the open-source office suite you actually own';
const description =
  'Casual Office is a real-time, file-centric, open-source office suite. Casual Sheets (web .xlsx) and Casual Editor (web .docx) round-trip native Office files, sync via Yjs CRDT, and run as a single self-hostable container. MIT + Apache-2.0. No accounts, no SaaS, no upsell.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://schnsrw.live/#person',
      name: 'Sachin Sarwa',
      url: 'https://schnsrw.live/',
      email: 'schnsrw@gmail.com',
      jobTitle: 'Software Engineer',
      sameAs: ['https://github.com/schnsrw', 'https://hub.docker.com/u/schnsrw'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://schnsrw.live/#website',
      url: 'https://schnsrw.live/',
      name: 'Casual Office',
      alternateName: 'schnsrw.live',
      description:
        'Open-source, real-time, file-centric office suite. Self-hostable. MIT + Apache-2.0.',
      publisher: { '@id': 'https://schnsrw.live/#person' },
      inLanguage: 'en',
    },
    {
      '@type': 'ItemList',
      '@id': 'https://schnsrw.live/#projects',
      name: 'Casual Office — projects',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          item: {
            '@type': 'SoftwareApplication',
            '@id': 'https://sheet.schnsrw.live/#app',
            name: 'Casual Sheets',
            applicationCategory: 'BusinessApplication',
            applicationSubCategory: 'SpreadsheetApplication',
            operatingSystem: 'Web Browser, Docker',
            url: 'https://sheet.schnsrw.live/',
            codeRepository: 'https://github.com/schnsrw/sheets',
            license: 'https://www.apache.org/licenses/LICENSE-2.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://schnsrw.live/#person' },
          },
        },
        {
          '@type': 'ListItem',
          position: 2,
          item: {
            '@type': 'SoftwareApplication',
            '@id': 'https://doc.schnsrw.live/#app',
            name: 'Casual Editor',
            applicationCategory: 'BusinessApplication',
            applicationSubCategory: 'WordProcessor',
            operatingSystem: 'Web Browser, Docker',
            url: 'https://doc.schnsrw.live/',
            codeRepository: 'https://github.com/schnsrw/docx',
            license: 'https://www.apache.org/licenses/LICENSE-2.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://schnsrw.live/#person' },
          },
        },
        {
          '@type': 'ListItem',
          position: 3,
          item: {
            '@type': 'SoftwareApplication',
            '@id': 'https://schnsrw.live/casual-desktop/#app',
            name: 'Casual Desktop',
            applicationCategory: 'DesktopEnhancementApplication',
            operatingSystem: 'macOS, Linux, Windows',
            url: 'https://schnsrw.live/casual-desktop/',
            license: 'https://www.apache.org/licenses/LICENSE-2.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://schnsrw.live/#person' },
          },
        },
      ],
    },
  ],
};

// Quickstart compose snippet. Held as a raw string and emitted via
// set:html so Astro doesn't try to interpolate the `${VAR}` segments.
const composeYml = `<code>services:
  app:
    image: schnsrw/casual-sheets:0.1
    ports: ['3000:3000']
    environment:
      CASUAL_STORAGE: local
      CASUAL_LOCAL_PATH: /data/workbooks
    volumes:
      - data:/data
volumes:
  data:</code>`;

// FAQ — collapsed via <details>. Plain markup so the source stays
// scannable and we don't ship JS for what HTML already does.
const faqs = [
  {
    q: 'What is Casual Office, in one sentence?',
    a: 'Two real office editors (sheets + docs) that open native Office files in the browser, sync in real time, and save back to the original byte-for-byte format — open source, MIT + Apache-2.0, self-hostable as one Docker container.',
  },
  {
    q: 'Is this a SaaS? Will it ever be?',
    a: 'No. The public demos at sheet.schnsrw.live and doc.schnsrw.live have no accounts, no plans, no upsell. The project is permissively licensed and free forever in the editions you can see today.',
  },
  {
    q: 'How does the .xlsx / .docx round-trip work?',
    a: 'The file is the source of truth. Open → in-memory snapshot → edit → re-serialize back to the original OOXML shape. Casual Sheets carries macros (vbaProject.bin) and pivot caches through byte-equal. Casual Editor scores 44/44 fixtures pristine in the per-tag fidelity audit.',
  },
  {
    q: 'Real-time co-editing — what powers it?',
    a: 'Yjs (industry-standard CRDT) in the browser, paired with Hocuspocus (Casual Sheets) or a custom ~120-line Go y-websocket gateway (Casual Editor). State lives in memory while a session is active; persistence is delegated to the host integration.',
  },
  {
    q: 'Do I need a database?',
    a: 'No. Default storage is in-memory or local-filesystem. Casual Sheets v0.1 also ships S3-compatible and Postgres backends — pick one with a single env var or skip them entirely.',
  },
  {
    q: 'Can I embed it in my own app?',
    a: 'Yes. Casual Editor ships as React packages on npm (`@eigenpal/docx-js-editor`). The Go gateway is a separate process you can run alongside any backend that speaks HTTP. Casual Sheets is currently a hosted shell; embedding APIs are planned for v0.2.',
  },
  {
    q: 'Where does it not fit?',
    a: 'If you need server-side PDF rendering, document versioning out of the box, enterprise SSO, or compliance certifications, this is not that. It is a focused open-source pair of editors, not a managed compliance suite.',
  },
  {
    q: 'Why does this exist?',
    a: 'A counterposition to megasuites. Each product is small enough to read end-to-end, every line is on GitHub, and the file format is owned by the user — not the vendor.',
  },
];
---
<Base {title} {description} active="home" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow">open source · self-host · MIT + Apache-2.0</span>
      <h1 class="display">
        Office software you <em>actually own.</em>
      </h1>
      <p class="lede">
        Two real editors for <code>.xlsx</code> and <code>.docx</code> — in the
        browser, with real-time multi-peer collab, that save back to the same
        byte-for-byte file. Open source. Self-hostable. No accounts, no SaaS, no
        upsell.
      </p>

      <div class="cmdline" role="group" aria-label="Run with Docker">
        <span class="cmdline__prompt">$</span>
        <code class="cmdline__cmd">docker run -p 3000:3000 schnsrw/casual-sheets:0.1</code>
        <span class="cmdline__hint">→ open localhost:3000</span>
      </div>

      <div class="row">
        <a class="btn btn--primary" href="https://github.com/schnsrw" rel="noopener" target="_blank" aria-label="View on GitHub">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" style="margin-right: 6px; vertical-align: -2px;">
            <path fill="currentColor" d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/>
          </svg>
          Star on GitHub
        </a>
        <a class="btn btn--ghost" href="https://sheet.schnsrw.live/">Open Sheets demo →</a>
        <a class="btn btn--ghost" href="https://doc.schnsrw.live/">Open Editor demo</a>
      </div>

      <p class="hero__trust">
        <span>Free forever</span><span aria-hidden="true">·</span>
        <span>No tracking</span><span aria-hidden="true">·</span>
        <span>No accounts</span><span aria-hidden="true">·</span>
        <span>Your files, your server</span>
      </p>
    </div>
  </section>

  <section class="section section--stats">
    <div class="container">
      <div class="statline">
        <div class="stat">
          <span class="stat__label">CASUAL EDITOR</span>
          <span class="stat__value">44/44</span>
          <span class="stat__hint">.docx fixtures · 100% round-trip</span>
        </div>
        <div class="stat">
          <span class="stat__label">CASUAL SHEETS</span>
          <span class="stat__value">v0.1.0</span>
          <span class="stat__hint">self-host shipped</span>
        </div>
        <div class="stat">
          <span class="stat__label">CO-EDIT</span>
          <span class="stat__value">live</span>
          <span class="stat__hint">verified end-to-end · Yjs CRDT</span>
        </div>
        <div class="stat">
          <span class="stat__label">LICENSE</span>
          <span class="stat__value">MIT + Apache</span>
          <span class="stat__hint">no AGPL, no copyleft surprises</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">two editors, one suite</span>
          <h2 class="title">A spreadsheet and a document editor.<br/>Read every line.</h2>
        </div>
        <span class="section__hint">/products</span>
      </div>
      <div class="products">
        <ProductCard
          slug="sheets"
          name="Casual Sheets"
          role="EXCEL-FLAVORED WEB SPREADSHEET"
          body="Open .xlsx, .ods, .csv, .tsv. Real-time co-editing, pivot tables with drill-down, 8 chart types with trendlines, sparklines, version history, and .xlsm macro passthrough that round-trips byte-equal."
          features={[
            '.xlsx · .ods · .csv · .tsv round-trip',
            'Pivot tables · 8 chart types · sparklines',
            'Real-time via Yjs + Hocuspocus',
            'Self-host: memory · local · S3 · Postgres',
          ]}
          status="v0.1.0 · 357 e2e"
          href="/casual-sheets/"
          accent="var(--sheets)"
          accentSoft="var(--sheets-soft)"
        />
        <ProductCard
          slug="editor"
          name="Casual Editor"
          role="WORD-FLAVORED .DOCX EDITOR"
          body="Open .docx in the browser with WYSIWYG fidelity. Fork of eigenpal/docx-editor on top of ProseMirror with an OOXML-preserving model. The stateless Go gateway speaks the y-websocket protocol in roughly 120 lines."
          features={[
            '.docx round-trip · 44/44 fixtures pristine',
            'ProseMirror + OOXML model · page color · table fidelity',
            'Yjs + Go y-websocket gateway',
            'Co-edit verified end-to-end (smoke + tests)',
          ]}
          status="M1 backend live · public preview"
          href="/casual-editor/"
          accent="var(--editor)"
          accentSoft="var(--editor-soft)"
        />
        <ProductCard
          slug="desktop"
          name="Casual Desktop"
          role="TAURI BINARIES · PAUSED"
          body="A native binary for macOS, Linux, and Windows that would reuse the web cores verbatim. Paused until both web editors reach feature parity; the work is queued, not abandoned."
          features={[
            'Tauri shell · reuses the web cores',
            'macOS · Linux · Windows',
            'Single-user · offline',
            'Resumes after web v1',
          ]}
          status="paused · queued"
          href="/casual-desktop/"
          accent="var(--desktop)"
          accentSoft="var(--desktop-soft)"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">why bother</span>
          <h2 class="title">What you don't get<br/>from a 700&#8209;MB SaaS dashboard.</h2>
        </div>
        <span class="section__hint">/why</span>
      </div>
      <div class="feature-grid feature-grid--four" style="--product-accent: var(--accent); --product-accent-soft: var(--accent-soft);">
        <article class="feature">
          <span class="feature__icon">①</span>
          <h3 class="feature__title">The file is the source of truth</h3>
          <p class="feature__body">
            Open <code>.xlsx</code> or <code>.docx</code>, edit, save back to the
            same bytes. The audit harness counts every OOXML tag round-trip;
            Casual Editor is at <strong>100% on 44 fixtures</strong>.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">②</span>
          <h3 class="feature__title">Stateless backend</h3>
          <p class="feature__body">
            No database, no on-disk update log in the real-time path. Session
            state lives in memory while peers are connected, then drains to
            the host integration on the last disconnect.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">③</span>
          <h3 class="feature__title">Real-time, actually working</h3>
          <p class="feature__body">
            Yjs CRDT in the browser, a custom <code>~120 LOC</code> Go gateway
            on the server. Multi-peer text, formatting, comments, presence
            cursors, even live document rename — verified by an end-to-end
            smoke that runs in five seconds.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">④</span>
          <h3 class="feature__title">One container, one port</h3>
          <p class="feature__body">
            Multi-arch images (amd64 + arm64) on Docker Hub. OCI labels, SBOM
            and provenance attestations. <code>docker run</code> and you're
            running both the editor and the WS gateway behind one URL.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">⑤</span>
          <h3 class="feature__title">Permissive, forever</h3>
          <p class="feature__body">
            MIT on the editor packages, Apache-2.0 on the backend. No
            copyleft, no AGPL trapdoor, no "open core" features hidden behind
            a paid tier. Fork it, embed it, ship it inside whatever you're
            building.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">⑥</span>
          <h3 class="feature__title">Built in the open</h3>
          <p class="feature__body">
            Every commit, every fixture, every failing-then-passing test
            visible on GitHub. The roadmap is a doc, not a slide deck. Pick
            an issue, open a PR, the bar is "did the suite stay green."
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">quickstart</span>
          <h2 class="title">From zero to a running editor in one command.</h2>
        </div>
        <span class="section__hint">docker</span>
      </div>
      <pre class="code-block" set:html={composeYml}></pre>
      <div class="row" style="margin-top: 20px;">
        <a class="btn btn--ghost" href="/docs/sheets/self-hosting/">Self-hosting guide →</a>
        <a class="btn btn--ghost" href="/docs/sheets/customization-auth/">Optional JWT auth</a>
        <a class="btn btn--ghost" href="/docs/">All docs</a>
      </div>
    </div>
  </section>

  <section class="section section--community">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">community-first</span>
          <h2 class="title">Help shape v1.</h2>
        </div>
        <span class="section__hint">/contribute</span>
      </div>
      <div class="community">
        <div class="community__card">
          <span class="community__num">★</span>
          <h3 class="community__title">Star the repos</h3>
          <p class="community__body">
            Stars are the only signal that says "keep going." Two repos:
            <a href="https://github.com/schnsrw/docx" rel="noopener" target="_blank">docx</a>
            for Casual Editor,
            <a href="https://github.com/schnsrw/sheets" rel="noopener" target="_blank">sheets</a>
            for Casual Sheets.
          </p>
        </div>
        <div class="community__card">
          <span class="community__num">✎</span>
          <h3 class="community__title">Open an issue</h3>
          <p class="community__body">
            Real-world <code>.docx</code> or <code>.xlsx</code> that breaks?
            Attach the file. Every regression fixture in the audit started
            life as someone's broken document.
          </p>
        </div>
        <div class="community__card">
          <span class="community__num">⤴</span>
          <h3 class="community__title">Send a PR</h3>
          <p class="community__body">
            The bar is the green CI suite plus a fixture that pins the
            change. Both repos have <code>CONTRIBUTING.md</code>; the
            <a href="https://github.com/schnsrw/docx/issues" rel="noopener" target="_blank">issue trackers</a>
            tag <code>good-first-issue</code>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">questions</span>
          <h2 class="title">Common questions.</h2>
        </div>
        <span class="section__hint">/faq</span>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <details class="faq__item">
            <summary class="faq__q">{f.q}</summary>
            <div class="faq__a">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--echo">
    <div class="container container--narrow">
      <h2 class="display display--small">Files in.<br/><em>Files out.</em></h2>
      <p class="lede">
        Casual Office is a small office suite built like infrastructure.
        Composable, file-shaped, permissive — closer to a UNIX tool than
        a SaaS product.
      </p>
      <div class="row" style="margin-top: 8px;">
        <a class="btn btn--primary" href="https://github.com/schnsrw" rel="noopener" target="_blank">Browse on GitHub →</a>
        <a class="btn btn--ghost" href="/docs/">Documentation</a>
        <a class="btn btn--ghost" href="/changelog/">Changelog</a>
      </div>
      <div class="row gap-sm" style="margin-top: 22px;">
        <span class="chip">Open source</span>
        <span class="chip">Self-hostable</span>
        <span class="chip">MIT + Apache-2.0</span>
        <span class="chip">Real-time, verified</span>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero command-line snippet — looks like a copy-pastable Docker
     command. Uses Space Mono so it reads as code immediately. */
  .cmdline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 13.5px;
    color: var(--text);
    margin: 6px 0 22px;
    max-width: 100%;
    overflow: auto;
  }
  .cmdline__prompt { color: var(--text-muted); user-select: none; }
  .cmdline__cmd { background: transparent; border: 0; padding: 0; color: var(--text); white-space: nowrap; }
  .cmdline__hint {
    color: var(--text-muted);
    font-size: 12px;
    white-space: nowrap;
    padding-left: 8px;
    border-left: 1px solid var(--border);
  }
  @media (max-width: 640px) {
    .cmdline { flex-wrap: wrap; }
    .cmdline__hint { border-left: 0; padding-left: 0; }
  }

  /* Trust strip directly under the hero CTAs — small, dim, monospace.
     Carries the "free forever / no tracking / no SaaS" promise that's
     the entire point of the project. */
  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 22px 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }
  .hero__trust span[aria-hidden] {
    opacity: 0.5;
  }

  /* Stats row — four narrow columns immediately below the hero,
     loud display value, dim mono label. */
  .section--stats { padding: 24px 0 48px; }
  .statline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .statline { grid-template-columns: repeat(2, 1fr); }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: var(--surface);
    padding: 18px 22px;
  }
  .stat__label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    font-weight: 700;
  }
  .stat__value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 26px;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .stat__hint {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--text-muted);
  }

  .feature-grid--four {
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 920px) { .feature-grid--four { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .feature-grid--four { grid-template-columns: 1fr; } }

  /* Quickstart code block — tighter than docs <pre>, fixed-width font,
     no scrollbar gymnastics. */
  .code-block {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    padding: 18px 22px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--text);
    overflow-x: auto;
    line-height: 1.6;
  }
  .code-block code {
    background: transparent;
    padding: 0;
    border: 0;
    color: inherit;
    font-size: inherit;
    white-space: pre;
  }

  /* Community section — three cards with a numeric-ish glyph that
     reinforces the "this is a checklist of how to participate" vibe.
     Matches the per-product card metrics without copying them. */
  .section--community {
    background: linear-gradient(180deg, transparent 0%, var(--surface) 100%);
  }
  .community {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 24px;
  }
  @media (max-width: 920px) { .community { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .community { grid-template-columns: 1fr; } }
  .community__card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 120ms ease;
  }
  .community__card:hover { border-color: var(--border-strong); }
  .community__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 18px;
    font-weight: 700;
    font-family: var(--font-display);
  }
  .community__title {
    font-family: var(--font-display);
    font-size: 17px;
